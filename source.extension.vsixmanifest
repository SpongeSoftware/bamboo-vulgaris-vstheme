<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011"
                 xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Id="BambooVulgaris.ColorTheme"
              Version="1.0.0"
              Language="en-US"
              Publisher="SpongeSoftware" />
    <DisplayName>Bamboo (Vulgaris)</DisplayName>
    <Description xml:space="preserve">A dark Visual Studio color theme mirroring the bamboo.nvim vulgaris palette.</Description>
    <MoreInfo>https://github.com/SpongeSoftware/bamboo-vulgaris-vstheme</MoreInfo>
    <Tags>theme;dark;color theme;bamboo;neovim</Tags>
    <ReleaseNotes>https://github.com/SpongeSoftware/bamboo-vulgaris-vstheme/blob/main/CHANGELOG.md</ReleaseNotes>
  </Metadata>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Community" Version="[17.0,)">
      <ProductArchitecture>amd64</ProductArchitecture>
    </InstallationTarget>
    <InstallationTarget Id="Microsoft.VisualStudio.Community" Version="[17.0,)">
      <ProductArchitecture>arm64</ProductArchitecture>
    </InstallationTarget>
    <InstallationTarget Id="Microsoft.VisualStudio.Professional" Version="[17.0,)">
      <ProductArchitecture>amd64</ProductArchitecture>
    </InstallationTarget>
    <InstallationTarget Id="Microsoft.VisualStudio.Professional" Version="[17.0,)">
      <ProductArchitecture>arm64</ProductArchitecture>
    </InstallationTarget>
    <InstallationTarget Id="Microsoft.VisualStudio.Enterprise" Version="[17.0,)">
      <ProductArchitecture>amd64</ProductArchitecture>
    </InstallationTarget>
    <InstallationTarget Id="Microsoft.VisualStudio.Enterprise" Version="[17.0,)">
      <ProductArchitecture>arm64</ProductArchitecture>
    </InstallationTarget>
  </Installation>
  <Prerequisites>
    <Prerequisite Id="Microsoft.VisualStudio.Component.CoreEditor" Version="[17.0,)" DisplayName="Visual Studio core editor" />
  </Prerequisites>
  <Assets>
    <Asset Type="Microsoft.VisualStudio.VsPackage" d:Source="File" Path="bamboo-vulgaris.pkgdef" />
    <Asset Type="Microsoft.VisualStudio.ColorTheme" d:Source="File" Path="bamboo-vulgaris.vstheme" />
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="README.md" />
  </Assets>
</PackageManifest>
