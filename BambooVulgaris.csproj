<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003" ToolsVersion="Current">
  <Import Project="$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props" Condition="Exists('$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props')" />
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Release</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">AnyCPU</Platform>
    <ProjectGuid>{B4E2F173-A8C5-4D6E-9F02-1B3C5D7E9F02}</ProjectGuid>
    <ProjectTypeGuids>{82b43b9b-a64c-4715-b499-d71e9ca2bd60};{FAE04EC0-301F-11D3-BF4B-00C04F79EFBC}</ProjectTypeGuids>
    <OutputType>Library</OutputType>
    <RootNamespace>BambooVulgaris</RootNamespace>
    <AssemblyName>BambooVulgaris.ColorTheme</AssemblyName>
    <TargetFrameworkVersion>v4.7.2</TargetFrameworkVersion>
    <OutputPath>bin\$(Configuration)\</OutputPath>
    <IntermediateOutputPath>obj\$(Configuration)\</IntermediateOutputPath>
    <GeneratePkgDefFile>false</GeneratePkgDefFile>
    <!-- Ship the assembly: the compiled theme pkgdef is registered as its VsPackage. -->
    <IncludeAssemblyInVSIXContainer>true</IncludeAssemblyInVSIXContainer>
    <IncludeDebugSymbolsInVSIXContainer>false</IncludeDebugSymbolsInVSIXContainer>
    <IncludeDebugSymbolsInLocalVSIXDeployment>false</IncludeDebugSymbolsInLocalVSIXDeployment>
    <CopyBuildOutputToOutputDirectory>true</CopyBuildOutputToOutputDirectory>
    <CopyOutputSymbolsToOutputDirectory>false</CopyOutputSymbolsToOutputDirectory>
    <UseCodebase>true</UseCodebase>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="Properties\AssemblyInfo.cs" />
  </ItemGroup>
  <ItemGroup>
    <None Include="source.extension.vsixmanifest">
      <SubType>Designer</SubType>
    </None>
    <!-- Compiled by VsixColorCompiler (globs **/*.vstheme) into a registered pkgdef. -->
    <None Include="bamboo-vulgaris.vstheme" />
  </ItemGroup>
  <ItemGroup>
    <Reference Include="System" />
  </ItemGroup>
  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />
  <!-- VSSDK targets from the NuGet package (no VS SDK MSI required on the build agent). -->
  <PropertyGroup>
    <VSSDKBuildToolsPath>$(MSBuildProjectDirectory)\packages\Microsoft.VSSDK.BuildTools.17.12.2069</VSSDKBuildToolsPath>
    <VsixColorCompilerPath>$(MSBuildProjectDirectory)\packages\Microsoft.VisualStudio.VsixColorCompiler.17.0.31709.430</VsixColorCompilerPath>
  </PropertyGroup>
  <Import Project="$(VSSDKBuildToolsPath)\tools\vssdk\Microsoft.VsSDK.targets" Condition="Exists('$(VSSDKBuildToolsPath)\tools\vssdk\Microsoft.VsSDK.targets')" />
  <!-- Compiles bamboo-vulgaris.vstheme -> compiled pkgdef and adds it to the VSIX. -->
  <Import Project="$(VsixColorCompilerPath)\build\Microsoft.VisualStudio.VsixColorCompiler.targets" Condition="Exists('$(VsixColorCompilerPath)\build\Microsoft.VisualStudio.VsixColorCompiler.targets')" />
</Project>
