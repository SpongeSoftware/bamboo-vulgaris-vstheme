<?xml version="1.0" encoding="utf-8"?>
<!--
  Bamboo (Vulgaris) — Visual Studio Theme
  Mirrors the bamboo.nvim vulgaris palette used in Neovim.

  Installation:
    Copy this file to:
      %LOCALAPPDATA%\Microsoft\VisualStudio\<version>\Themes\
    Then restart Visual Studio and select via:
      Tools > Options > Environment > General > Color Theme

    Alternatively, install the "Color Theme Manager" extension
    and use its Import button.

  Palette reference (matches wezterm + neovim bamboo.nvim vulgaris):
    bg0          #252623   main background
    bg1          #2f312c   panels / cursor line
    bg2          #383b35   inactive / borders
    bg3          #3a3d37   selection
    bg_d         #1c1e1b   deep background / title bar
    fg           #f1e9d2   normal text
    grey         #5b5e5a   comments / line numbers
    light_grey   #838781   dimmed text / delimiters
    red          #e75a7c   variables / errors / labels
    green        #8fb573   strings / interfaces
    yellow       #dbb651   types / classes / structs / enums
    blue         #57a5e5   functions / methods / tags
    purple       #aaaaff   keywords / hints
    light_purple #c5c2ee   operators (blend purple+fg at 0.375)
    cyan         #70c2be   properties / events / info
    orange       #ff9966   constants / numbers / escape chars
    light_blue   #96c7ef   namespaces
    bright_purple #df73ff  type parameters
    diff_add     #40531b
    diff_delete  #893f45
    diff_change  #2a3a57
-->
<Themes>
  <Theme Name="Bamboo (Vulgaris)" GUID="{b4e2f173-a8c5-4d6e-9f02-1b3c5d7e9f01}"
         FallbackId="{1ded0138-47ce-435e-84ef-9ec1f439b749}">

